---
import { siInstagram } from "simple-icons";
import { Share2, Check } from "@lucide/astro";
---

<footer>
  <div class="footer-logo">LÍO<span> EL BONILLO</span></div>

  <div class="footer-social">
    <span class="footer-social-label">Síguenos</span>
    <a
      class="social-link"
      href="https://www.instagram.com/lioelbonillo/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram de Lío El Bonillo"
    >
      <svg class="social-icon" role="img" viewBox="0 0 24 24" aria-hidden="true">
        <path d={siInstagram.path}></path>
      </svg>
      <span>@lioelbonillo</span>
    </a>
    <button class="social-link share-btn" type="button" data-share aria-label="Compartir la web de Lío El Bonillo">
      <Share2 class="social-icon share-ico-share" size={18} stroke-width={1.5} />
      <Check class="social-icon share-ico-ok" size={18} stroke-width={1.5} />
      <span class="share-text">Compartir</span>
    </button>
  </div>

  <div class="footer-meta">
    <p>Plaza Mayor · El Bonillo · Albacete</p>
    <p class="footer-copy">© 2025 Lío El Bonillo</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-logo {
    font-family: var(--font-logo);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  .footer-logo span {
    color: var(--muted);
  }
  .footer-social {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .footer-social-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .social-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 18px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .social-icon {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  /* El botón de compartir usa iconos de trazo (Lucide), no relleno. */
  .share-btn {
    cursor: pointer;
    background: transparent;
  }
  .share-btn .social-icon {
    fill: none;
    stroke: currentColor;
  }
  .share-ico-ok {
    display: none;
    color: var(--accent2);
  }
  .share-btn.copied .share-ico-share {
    display: none;
  }
  .share-btn.copied .share-ico-ok {
    display: inline-block;
  }
  .share-btn.copied {
    color: var(--accent2);
    border-color: var(--accent2);
  }
  .footer-meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-align: right;
  }
  .footer-copy {
    margin-top: 4px;
    color: rgba(107, 107, 128, 0.5);
  }

  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
    .footer-meta {
      text-align: center;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-share]");
  const textEl = btn?.querySelector<HTMLSpanElement>(".share-text");

  btn?.addEventListener("click", async () => {
    const shareData = {
      title: "Lío El Bonillo",
      text: "Disco pub en El Bonillo (Albacete). Carteles del finde, galería de fotos y premio semanal 🪩",
      url: window.location.origin,
    };

    if (navigator.share) {
      try {
        await navigator.share(shareData);
        return;
      } catch {
        /* el usuario canceló o falló: caemos al copiado */
      }
    }

    try {
      await navigator.clipboard.writeText(shareData.url);
      btn.classList.add("copied");
      if (textEl) textEl.textContent = "¡Copiado!";
      setTimeout(() => {
        btn.classList.remove("copied");
        if (textEl) textEl.textContent = "Compartir";
      }, 1800);
    } catch {
      /* sin portapapeles disponible */
    }
  });
</script>
