---
interface Props {
  titulo: string;
  fecha: string;
  badge: string;
}

const { titulo, fecha, badge } = Astro.props;
---

<section class="section" id="carteles">
  <p class="section-label">// 01 — Esta semana</p>
  <h2 class="section-title">Cartel<br />del finde</h2>

  <div class="cartel-grid">
    <!-- Cartel principal -->
    <div class="cartel-main">
      <div class="cartel-placeholder">
        <div class="cartel-placeholder-text">CARTEL<br />FINDE</div>
      </div>
      <span class="cartel-badge">{badge}</span>
      <h3 class="cartel-title">{titulo}</h3>
      <p class="cartel-date">{fecha}</p>
    </div>
    <!-- Finde anterior -->
    <div class="cartel-side">
      <div>
        <span class="cartel-side-label">// Finde anterior</span>
        <h4 class="cartel-side-title">Sesión especial</h4>
      </div>
      <p class="cartel-side-meta">Consulta los carteles pasados en la galería</p>
      <div class="cartel-side-num">01</div>
    </div>
    <!-- Próximamente -->
    <div class="cartel-side">
      <div>
        <span class="cartel-side-label" style="color:var(--accent3)"
          >// Próximamente</span
        >
        <h4 class="cartel-side-title">Evento especial</h4>
      </div>
      <p class="cartel-side-meta">Pendiente de confirmar. Síguenos.</p>
      <div class="cartel-side-num">02</div>
    </div>
  </div>
</section>

<style>
  .cartel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .cartel-main {
    grid-row: span 2;
    position: relative;
    background: var(--surface);
    min-height: 520px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    overflow: hidden;
  }
  .cartel-placeholder {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 30px,
      rgba(200, 240, 38, 0.02) 30px,
      rgba(200, 240, 38, 0.02) 31px
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cartel-placeholder-text {
    font-family: var(--font-display);
    font-size: 5rem;
    color: rgba(200, 240, 38, 0.06);
    letter-spacing: 0.1em;
    text-align: center;
  }
  .cartel-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: var(--accent);
    color: var(--bg);
    padding: 5px 12px;
    font-weight: 700;
    margin-bottom: 12px;
    width: fit-content;
  }
  .cartel-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--text);
    position: relative;
  }
  .cartel-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-top: 8px;
    position: relative;
  }

  .cartel-side {
    background: var(--surface);
    padding: 32px;
    min-height: 259px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    transition: background 0.2s;
  }
  .cartel-side:hover {
    background: #181826;
  }
  .cartel-side-num {
    font-family: var(--font-display);
    font-size: 5rem;
    color: rgba(255, 255, 255, 0.04);
    line-height: 1;
    position: absolute;
    right: 20px;
    bottom: 10px;
  }
  .cartel-side-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent2);
  }
  .cartel-side-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
    margin-top: 8px;
  }
  .cartel-side-meta {
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .cartel-grid {
      grid-template-columns: 1fr;
    }
    .cartel-main {
      grid-row: span 1;
      min-height: 320px;
    }
  }
</style>
