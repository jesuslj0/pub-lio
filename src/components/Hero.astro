---
import { Disc3 } from "@lucide/astro";
---

<section class="hero">
  <div class="hero-bg"></div>
  <p class="hero-eyebrow"><Disc3 size={14} stroke-width={2} /> Music Pub · El Bonillo (AB)</p>
  <h1 class="hero-title">
    <span class="stroke-text">te</span>
    vas
    <span class="accent-word">a liar</span>
    <span class="sr-only"> — Lío, disco pub en El Bonillo (Albacete)</span>
  </h1>
  <div class="hero-sub">
    <p>
      Sonido y luz de <strong>última generación.</strong> Copas, tapas y cañas.
      <strong>El plan del finde</strong> en El Bonillo.
    </p>
    <div class="hero-scroll">scroll</div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 40px 40px;
    position: relative;
    overflow: hidden;
  }

  /* Photo background */
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("/img/dj-pov-b&w.jpg"); /* fallback navegadores sin image-set */
    background-image: image-set(
      url("/img/dj-pov-b&w.webp") type("image/webp"),
      url("/img/dj-pov-b&w.jpg") type("image/jpeg")
    );
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    opacity: 0.75;
    z-index: -1;
    top: -100px;
  }
  /* Darkening overlay so the title stays legible */
  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--bg) 0%,
      rgba(8, 8, 16, 0.45) 35%,
      rgba(8, 8, 16, 0.9) 100%
    );
  }

  @keyframes float1 {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-40px, 40px) scale(1.1);
    }
  }
  @keyframes float2 {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(60px, -30px);
    }
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    padding: 7px 14px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(5rem, 14vw, 13rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--text);
    position: relative;
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero-title .accent-word {
    color: var(--accent);
    display: block;
  }
  .hero-title .stroke-text {
    -webkit-text-stroke: 2.5px rgba(232, 232, 240, 0.4);
    color: transparent;
    display: block;
  }
  .hero-sub {
    margin-top: 32px;
    display: flex;
    align-items: start;
    gap: 48px;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }
  .hero-sub p {
    font-size: 1rem;
    color: var(--muted);
    max-width: 340px;
    font-weight: 300;
    font-style: italic;
  }
  .hero-sub p strong {
    color: var(--text);
    font-weight: 500;
    font-style: italic;
  }
  .hero-scroll {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }
  .hero-scroll::after {
    content: "";
    width: 1px;
    height: 60px;
    background: linear-gradient(var(--muted), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 769px) {
    .hero {
      min-height: calc(100vh - 48px);
      padding-bottom: 88px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 48px);
      padding: 96px 20px 32px;
      justify-content: flex-start;
    }
    .hero-bg {
      background-position: 73% center;
    }

    .hero-sub {
      margin-top: auto;
    }

    .hero-title {
      font-size: clamp(4rem, 18vw, 7rem);
    }
    .hero-sub {
      flex-direction: column;
      gap: 24px;
    }
    .hero-scroll {
      display: none;
    }

  }
</style>
