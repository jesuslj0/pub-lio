---
import { LocateFixed } from "lucide-react";
import { Picture } from "astro:assets";
import neonNacion from "../assets/img/neon-nacion.jpeg";
---

<section class="nacion">
  <div class="nacion-content">
    <p class="nacion-eyebrow"><LocateFixed size={14} strokeWidth={2} />· El lugar</p>
    <h2 class="nacion-title">La Nación<br />del <span class="accent-word">buen rollo</span></h2>
    <p class="nacion-body">
      Donde <span class="mark">cada noche pasa algo.</span> Buena música, copas y una pista que nunca se queda vacía. 
      Caras conocidas, gente nueva y la <span class="mark">energía que hace único a Lío.</span>
      El plan del finde en El Bonillo <span class="mark">desde siempre.</span>
    </p>
  </div>

  <div class="nacion-media">
    <Picture
      src={neonNacion}
      formats={["avif", "webp"]}
      alt="Ambiente neón en el Lío El Bonillo"
      loading="lazy"
      decoding="async"
    />
    <div class="nacion-media-fade"></div>
  </div>
</section>

<style>
  .nacion {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: stretch;
    overflow: hidden;
    margin-bottom: 60px;
    min-height: 70vh;
    background: var(--bg2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .nacion-content {
    max-width: 640px;
    align-self: center;
    z-index: 2;
    padding: 60px 60px 60px 80px;
  }

  .nacion-media {
    position: relative;
  }

  .nacion-media picture {
    position: absolute;
    inset: 0 48px 0 0;
    display: block;
  }
  .nacion-media img {
    width: auto;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .nacion-media-fade {
    position: absolute;
    inset: 0;
    pointer-events: none;

    background:
      linear-gradient(to right, var(--bg2) 0%, rgba(14, 14, 26, 0) 30%),
      linear-gradient(to left, var(--bg2) 0%, rgba(14, 14, 26, 0) 18%),
      linear-gradient(to bottom, var(--bg2) 0%, rgba(14, 14, 26, 0) 16%),
      linear-gradient(to top, var(--bg2) 0%, rgba(14, 14, 26, 0) 16%);
  }

  .nacion-eyebrow {
    display: inline-flex; 
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .nacion-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 8rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 28px;
  }

  .nacion-body {
    font-size: 1rem;
    color: var(--muted);
    font-weight: 300;
    font-style: italic;
    max-width: 480px;
    line-height: 1.7;
  }

  .nacion-body strong {
    color: var(--text);
    font-weight: 500;
    font-style: normal;
  }

  .accent-word {
    color: var(--color-accent)
  }

  .mark {
    color: var(--color-text);
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .nacion {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .nacion-content {
      padding: 40px 24px 60px;
    }
    .nacion-media {
      order: -1;
      height: 38vh;
    }
    .nacion-media picture {
      inset: 0;
    }
    .nacion-media img {
      width: 100%;
      object-position: center;
    }
    .nacion-media-fade {
      background:
        linear-gradient(to bottom, var(--bg2) 0%, rgba(14, 14, 26, 0) 14%),
        linear-gradient(to top, var(--bg2) 0%, rgba(14, 14, 26, 0) 24%),
        linear-gradient(to right, var(--bg2) 0%, rgba(14, 14, 26, 0) 12%),
        linear-gradient(to left, var(--bg2) 0%, rgba(14, 14, 26, 0) 12%);
    }
  }
</style>
