---
import VoteButton from "./VoteButton.tsx";

interface Photo {
  id: string | number;
  src?: string;
  votes: number;
  winner?: boolean;
}

interface Props {
  photos?: Photo[];
}

const { photos = [] } = Astro.props;
---

<section class="section" id="fotos" style="padding-top: 0;">
  <div class="fotos-header">
    <div>
      <p class="section-label">// 02 — Galería</p>
      <h2 class="section-title">Fotos<br />del finde</h2>
    </div>
    <div style="text-align:right; padding-bottom: 8px;">
      <p
        style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.15em; color:var(--muted); text-transform:uppercase;"
      >
        La más votada gana el finde siguiente
      </p>
      <p
        style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.1em; color:var(--accent); margin-top:6px;"
      >
        Premio activo en temporada ↗
      </p>
    </div>
  </div>

  <div class="fotos-grid">
    {
      photos.map((photo) => (
        <div class="foto-card">
          {photo.winner && (
            <div class="foto-winner-badge">★ Más votada</div>
          )}
          {photo.src ? (
            <img class="foto-img" src={photo.src} alt="Foto del finde" />
          ) : (
            <div class="foto-placeholder">
              <span class="foto-placeholder-icon">▣</span>
            </div>
          )}
          <div class="foto-overlay">
            <VoteButton id={photo.id} votes={photo.votes} client:load />
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .fotos-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 24px;
  }
  .fotos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--border);
  }
  .foto-card {
    background: var(--surface);
    aspect-ratio: 3/4;
    position: relative;
    overflow: hidden;
    cursor: none;
  }
  .foto-card:hover .foto-overlay {
    opacity: 1;
  }
  .foto-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .foto-winner-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 10px;
  }
  .foto-placeholder {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      -45deg,
      var(--surface),
      var(--surface) 20px,
      rgba(255, 255, 255, 0.015) 20px,
      rgba(255, 255, 255, 0.015) 21px
    );
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .foto-placeholder-icon {
    font-size: 2rem;
    color: rgba(255, 255, 255, 0.08);
    font-family: var(--font-mono);
  }
  .foto-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 8, 16, 0.9) 0%,
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.25s;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px;
  }

  /* Estilos del botón de voto (componente React VoteButton) */
  :global(.foto-vote) {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  :global(.foto-vote-btn) {
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 6px 14px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: none;
    transition: transform 0.15s;
  }
  :global(.foto-vote-btn):hover {
    transform: scale(1.04);
  }

  @media (max-width: 768px) {
    .fotos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .fotos-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
