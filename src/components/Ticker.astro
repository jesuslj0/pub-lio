---
import {
  Wine,
  UtensilsCrossed,
  Beer,
  Gamepad2,
  Target,
  Music,
  Headphones,
  Trophy,
  LensConcave
} from "@lucide/astro";

const items = [
  { label: "Copas", icon: Wine },
  { label: "Tapas", icon: UtensilsCrossed },
  { label: "Cañas", icon: Beer },
  { label: "Futbolín", icon: Gamepad2 },
  { label: "Diana", icon: Target },
  { label: "Shishas", icon: LensConcave},
  { label: "Música en directo", icon: Music },
  { label: "DJ invitados", icon: Headphones },
  { label: "Premios semanales", icon: Trophy },
];
---

<div class="ticker">
  <div class="ticker-track">
    {
      items.map(({ label, icon: Icon }) => (
        <span class="ticker-item">
          <Icon size={15} stroke-width={2} />
          {label}
        </span>
      ))
    }
    {/* duplicado para loop continuo */}
    {
      items.map(({ label, icon: Icon }) => (
        <span class="ticker-item">
          <Icon size={15} stroke-width={2} />
          {label}
        </span>
      ))
    }
  </div>
</div>

<style>
  .ticker {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    padding: 14px 0;
    position: relative;
  }
  .ticker-track {
    display: flex;
    gap: 0;
    width: max-content;
    animation: tickerScroll 22s linear infinite;
    white-space: nowrap;
    will-change: transform;
    transform: translateZ(0);
    backface-visibility: hidden;
  }
  .ticker:hover .ticker-track {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
  .ticker-item {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 40px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ticker-item svg {
    color: var(--accent);
  }
  .ticker-item::after {
    content: "·";
    color: var(--accent);
    margin-left: 12px;
  }
  @keyframes tickerScroll {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }
</style>
