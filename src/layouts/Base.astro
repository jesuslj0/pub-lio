---
import "../styles/global.css";
import LiquidAurora from "../components/LiquidAurora.astro";

interface Props {
  title?: string;
}

const { title = "Lío El Bonillo" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Favicons -->
    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content="#080810" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <LiquidAurora />
    <div class="cursor" id="cursor"></div>
    <div class="cursor-ring" id="cursorRing"></div>

<slot />

    <script>
      // Cursor personalizado — solo en punteros finos (ratón). En táctil se
      // omite por completo: ni listeners ni rAF.
      const finePointer = window.matchMedia("(pointer: fine)").matches;
      const cursor = document.getElementById("cursor");
      const ring = document.getElementById("cursorRing");

      if (finePointer && cursor && ring) {
        let mx = window.innerWidth / 2,
          my = window.innerHeight / 2,
          rx = mx,
          ry = my,
          raf = 0;

        // Posiciona con transform (compositado, sin layout/repaint).
        function place(el: HTMLElement, x: number, y: number) {
          el.style.transform = `translate3d(${x}px, ${y}px, 0) translate(-50%, -50%)`;
        }

        function render() {
          place(cursor, mx, my);
          rx += (mx - rx) * 0.15;
          ry += (my - ry) * 0.15;
          place(ring, rx, ry);
          // Detén el bucle cuando el anillo alcanza al cursor.
          if (Math.abs(mx - rx) < 0.1 && Math.abs(my - ry) < 0.1) {
            raf = 0;
          } else {
            raf = requestAnimationFrame(render);
          }
        }

        function kick() {
          if (!raf) raf = requestAnimationFrame(render);
        }

        window.addEventListener(
          "mousemove",
          (e) => {
            mx = e.clientX;
            my = e.clientY;
            kick();
          },
          { passive: true },
        );

        // Hover por delegación: una sola pareja de listeners para toda la página.
        const HOVER = "a, button, .foto-card, .cartel-side";
        document.addEventListener("mouseover", (e) => {
          if ((e.target as Element).closest(HOVER))
            document.body.classList.add("cursor-hover");
        });
        document.addEventListener("mouseout", (e) => {
          if ((e.target as Element).closest(HOVER))
            document.body.classList.remove("cursor-hover");
        });

        place(cursor, mx, my);
        place(ring, rx, ry);
      }
    </script>
  </body>
</html>

<style is:global>
  /* Alias cortos → tokens de @theme (Tailwind). Fuente única de verdad en
     src/styles/global.css. Las fuentes (--font-*) ya las provee @theme. */
  :root {
    --bg: var(--color-bg);
    --bg2: var(--color-bg2);
    --surface: var(--color-surface);
    --border: var(--color-border);
    --accent: var(--color-accent);
    --accent2: var(--color-accent2);
    --accent3: var(--color-accent3);
    --text: var(--color-text);
    --muted: var(--color-muted);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
    /* La posición la fija JS vía transform; aquí solo el tamaño/color. */
    transition:
      width 0.2s ease,
      height 0.2s ease,
      background 0.2s ease;
    mix-blend-mode: exclusion;
  }
  .cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    width: 36px;
    height: 36px;
    border: 1px solid var(--accent);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    will-change: transform;
    transition:
      width 0.2s ease,
      height 0.2s ease,
      opacity 0.2s ease;
    opacity: 0.5;
  }

  /* Estado hover sobre elementos interactivos (toggle por clase en <body>). */
  .cursor-hover .cursor {
    width: 20px;
    height: 20px;
  }
  .cursor-hover .cursor-ring {
    width: 56px;
    height: 56px;
    opacity: 0.8;
  }

  /* Noise overlay */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.03;
    pointer-events: none;
    z-index: 1000;
  }

  /* ─── SHARED SECTION PRIMITIVES ─── */
  .section {
    padding: 100px 40px;
    position: relative;
  }
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 48px;
  }

  @media (max-width: 768px) {
    .section {
      padding: 60px 20px;
    }
    body {
      cursor: auto;
    }
    .cursor,
    .cursor-ring {
      display: none;
    }
  }
</style>
