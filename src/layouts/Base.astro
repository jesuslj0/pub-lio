---
import "../styles/global.css";
import LiquidAurora from "../components/LiquidAurora.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "Lío El Bonillo",
  description = "Disco pub en El Bonillo (Albacete). Carteles del finde, galería de fotos del público y premio semanal a la foto más votada. Copas, música y buen ambiente cada viernes y sábado.",
  image = "/img/og-default.png",
  noindex = false,
} = Astro.props;

// URL canónica y absoluta para OG. Si no hay site configurado, usamos el origin de la request.
const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NightClub",
  name: "Lío El Bonillo",
  description,
  url: site.href,
  image: ogImage,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Plaza Mayor",
    addressLocality: "El Bonillo",
    addressRegion: "Albacete",
    addressCountry: "ES",
  },
  sameAs: ["https://www.instagram.com/lioelbonillo/"],
  openingHours: ["Fr 20:00-04:00", "Sa 20:00-04:00"],
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph (WhatsApp, Instagram, Facebook…) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lío El Bonillo" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Datos estructurados (Google) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content="#080810" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wdth,wght@125,700;125,800&family=Space+Grotesk:wght@300;400;500;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <LiquidAurora />

<slot />
  </body>
</html>

<style is:global>
  /* Alias cortos → tokens de @theme (Tailwind). Fuente única de verdad en
     src/styles/global.css. Las fuentes (--font-*) ya las provee @theme. */
  :root {
    --bg: var(--color-bg);
    --bg2: var(--color-bg2);
    --surface: var(--color-surface);
    --border: var(--color-border);
    --accent: var(--color-accent);
    --accent2: var(--color-accent2);
    --accent3: var(--color-accent3);
    --text: var(--color-text);
    --muted: var(--color-muted);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Saltar al contenido (teclado / lectores de pantalla) */
  .skip-link {
    position: fixed;
    top: 8px;
    left: 8px;
    z-index: 1001;
    transform: translateY(-150%);
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 16px;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  .skip-link:focus {
    transform: translateY(0);
  }

  /* Foco visible coherente con la marca */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Respetar preferencia de movimiento reducido */
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* Noise overlay */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.03;
    pointer-events: none;
    z-index: 1000;
  }

  /* ─── SHARED SECTION PRIMITIVES ─── */
  .section {
    padding: 100px 40px;
    position: relative;
  }
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 48px;
  }

  @media (max-width: 768px) {
    .section {
      padding: 60px 20px;
    }
  }
</style>
