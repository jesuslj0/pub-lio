---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Ticker from "../components/Ticker.astro";
import CartelFinde from "../components/CartelFinde.tsx";
import PhotoGrid from "../components/PhotoGrid.tsx";
import PhotoUploader from "../components/PhotoUploader.tsx";
import PremioSemanal from "../components/PremioSemanal.tsx";
import Leaderboard from "../components/Leaderboard.tsx";
import NacionSection from "../components/NacionSection.astro";
import InfoStrip from "../components/InfoStrip.astro";
import ComoParticipar from "../components/ComoParticipar.astro";
import Footer from "../components/Footer.astro";
import { CalendarDays, Images, Gift, ListChecks } from "@lucide/astro";
---

<Base title="Lío Music Pub · El Bonillo (Albacete)">
  <Nav />
  <main id="contenido">
  <Hero />
  <Ticker />

  <!-- CARTELES -->
  <section class="section" id="carteles">
    <p class="section-label"><CalendarDays size={14} stroke-width={2} />· Esta semana</p>
    <h2 class="section-title">Cartel<br />del finde</h2>
    <div class="cartel-wrap">
      <CartelFinde client:load />
    </div>
  </section>

  <!-- FOTOS -->
  <section class="section" id="fotos" style="padding-top: 0;">
    <div class="fotos-header">
      <div>
        <p class="section-label"><Images size={14} stroke-width={2} />· Galería</p>
        <h2 class="section-title">Fotos<br />del finde</h2>
      </div>
      <div style="text-align:right; padding-bottom: 8px;">
        <p class="fotos-note">La más votada gana el finde siguiente</p>
        <a href="#premio" class="fotos-note accent fotos-note-link">Ver premio activo ↗</a>
      </div>
    </div>
    <PhotoGrid client:load mostrarGanadora={true} />
  </section>

  <!-- PREMIO SEMANAL -->
  <section class="section" id="premio" style="padding-top: 0;">
    <p class="section-label"><Gift size={14} stroke-width={2} />· Premio</p>
    <h2 class="section-title">Premio<br /> semanal</h2>
    <div class="premio-wrap">
      <div class="premio-card-col">
        <PremioSemanal client:load />
      </div>
      <div class="premio-lb-col">
        <Leaderboard client:load />
      </div>
    </div>
  </section>

  <!-- SUBIR FOTO + CÓMO PARTICIPAR -->
  <section class="section" id="subir" style="padding-top: 0;">
    <p class="section-label"><ListChecks size={14} stroke-width={2} />· Participa</p>
    <div class="upload-grid">
      <div class="upload-left">
        <h2 class="upload-left-title">¿Estuviste<br />con nosotros?</h2>
        <p class="upload-left-sub">
          Sube tu <span class="mark">mejor foto del finde</span> en el Lío, consigue votos y gana el <span class="mark">premio</span> de la semana
          siguiente. Sin registro: solo tu foto y un nombre. Máximo 3 fotos por
          dispositivo. <span class="mark" style="font-style: italic">Comparte tu momento!</span>
        </p>
      </div>
      <div class="upload-right">
        <PhotoUploader client:load />
      </div>
    </div>

    <ComoParticipar />
  </section>

  <NacionSection />
  <InfoStrip />
  </main>
  <Footer />
</Base>

<style>
  .cartel-wrap {
    max-width: 860px;
    margin: 0 auto;
  }
  .premio-wrap {
    max-width: 1140px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }
  .fotos-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 24px;
  }
  .fotos-note {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .fotos-note.accent {
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-top: 6px;
  }
  .fotos-note-link {
    display: inline-block;
    text-decoration: none;
    transition:
      opacity 0.2s ease,
      text-shadow 0.2s ease;
  }
  .fotos-note-link:hover {
    text-shadow: 0 0 12px color-mix(in srgb, var(--accent) 50%, transparent);
    opacity: 0.85;
  }

  .upload-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    margin-bottom: 72px;
  }
  .upload-left-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 0.92;
    color: var(--text);
    letter-spacing: 0.02em;
  }
  .upload-left-sub {
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 300;
    max-width: 360px;
    margin-top: 16px;
  }
  .upload-right {
    display: flex;
    justify-content: flex-end;
  }

  .mark {
    color: var(--color-text);
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .premio-wrap {
      grid-template-columns: 1fr;
      max-width: 760px;
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .fotos-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .upload-grid {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-bottom: 48px;
    }
    .upload-right {
      justify-content: flex-start;
    }
  }
</style>
