---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Ticker from "../components/Ticker.astro";
import CartelFinde from "../components/CartelFinde.tsx";
import PhotoGrid from "../components/PhotoGrid.tsx";
import PhotoUploader from "../components/PhotoUploader.tsx";
import PremioSemanal from "../components/PremioSemanal.tsx";
import Leaderboard from "../components/Leaderboard.tsx";
import GaleriaLocal from "../components/GaleriaLocal.astro";
import NacionSection from "../components/NacionSection.astro";
import InfoStrip from "../components/InfoStrip.astro";
import ComoParticipar from "../components/ComoParticipar.astro";
import Footer from "../components/Footer.astro";
import { CalendarDays, Images, Gift, ListChecks, ShieldCheck, UserCheck } from "@lucide/astro";
import { getPreviousWeek } from "../lib/supabase";

// Semana de concurso recién cerrada: su podio se muestra como "anteriores
// ganadores" hasta que la semana en curso genere el suyo (rota cada jueves).
const semanaPasada = getPreviousWeek();
---

<Base title="Lío Music Pub · El Bonillo (Albacete)">
  <Nav />
  <main id="contenido">
  <Hero />
  <Ticker />

  <!-- CARTELES -->
  <section class="section" id="carteles">
    <p class="section-label"><CalendarDays size={14} stroke-width={2} />· Esta semana</p>
    <h2 class="section-title">Cartel<br />del finde</h2>
    <div class="cartel-wrap">
      <CartelFinde client:load />
    </div>
  </section>

  <!-- FOTOS -->
  <section class="section" id="fotos" style="padding-top: 0;">
    <div class="fotos-header">
      <div>
        <p class="section-label"><Images size={14} stroke-width={2} />· feed</p>
        <h2 class="section-title fotos-title">Liad@s</h2>
        <p class="fotos-sub">Mira cómo se lió el finde</p>
      </div>
    </div>
    <PhotoGrid client:load mostrarGanadora={true} />
  </section>

  <!-- PREMIO SEMANAL -->
  <section class="section" id="premio" style="padding-top: 0;">
    <p class="section-label"><Gift size={14} stroke-width={2} />· Premio</p>
    <h2 class="section-title">Premio<br /> semanal</h2>

    <!-- Finde actual -->
    <p class="premio-bloque-label">Finde actual</p>
    <div class="premio-wrap">
      <div class="premio-card-col">
        <PremioSemanal client:load />
      </div>
      <div class="premio-lb-col">
        <Leaderboard client:load />
      </div>
    </div>

    <!-- Anteriores ganadores (semana pasada) -->
    <div class="premio-pasada-wrap premio-pasada-wrap--gap">
      <Leaderboard client:load semana={semanaPasada} variante="resultados" />
    </div>
  </section>

  <!-- SUBIR FOTO + CÓMO PARTICIPAR -->
  <section class="section" id="subir" style="padding-top: 0;">
    <p class="section-label"><ListChecks size={14} stroke-width={2} />· Participa</p>
    <div class="upload-grid">
      <div class="upload-left">
        <h2 class="upload-left-title">¿Estuviste<br />con nosotros?</h2>
        <p class="upload-left-sub">
          Sube tu <span class="mark">mejor foto del finde</span> en el Lío, consigue votos y gana el <span class="mark">premio</span> de la semana
          siguiente. Sin registro: solo tu foto y un nombre. Máximo 3 fotos por
          dispositivo. <span class="mark" style="font-style: italic">¡Comparte tu momento!</span>
        </p>
      </div>
      <div class="upload-right">
        <ComoParticipar />
        <div class="upload-uploader" id="subir-foto">
          <PhotoUploader client:load />
          <div class="upload-avisos">
            <p class="upload-aviso">
              <ShieldCheck size={14} stroke-width={2} />
              <span>
                Cada imagen <span class="mark">pasa revisión</span> antes de
                publicarse: puede validarse o no. No subas fotos ofensivas ni sin
                consentimiento — una vez validadas serán
                <span class="mark">públicas</span> para todo el que visite la web.
                Las imágenes se usan <span class="mark">únicamente</span> para esta
                galería y el concurso, no se ceden a terceros y se
                <span class="mark">eliminan automáticamente</span> pasado un tiempo.
              </span>
            </p>
            <p class="upload-aviso">
              <UserCheck size={14} stroke-width={2} />
              <span>
                Si tu foto resulta <span class="mark">ganadora</span>, verificaremos
                la autoría a través del Instagram indicado. Si no podemos
                confirmarla o la cuenta no coincide con la foto, se
                <span class="mark">reelegirá un nuevo ganador</span>.
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <NacionSection />
  <GaleriaLocal />
  <InfoStrip />
  </main>
  <Footer />
</Base>

<style>
  .cartel-wrap {
    max-width: 1100px;
    margin: 0 auto;
  }
  .premio-wrap {
    max-width: 1140px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }
  .premio-bloque-label {
    max-width: 1140px;
    margin: 0 auto 18px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .premio-pasada-wrap {
    max-width: 1140px;
    margin: 0 auto;
  }
  .premio-pasada-wrap--gap {
    margin-top: 48px;
  }
  .fotos-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 24px;
  }
  .fotos-title {
    margin-bottom: 10px;
  }
  .fotos-sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-muted);
  }
  .fotos-sub::after {
    content: "";
    display: block;
    width: 56px;
    height: 3px;
    margin-top: 14px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), var(--accent3));
  }
  .fotos-note {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .fotos-note.accent {
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-top: 6px;
  }
  .fotos-note-link {
    display: inline-block;
    text-decoration: none;
    transition:
      opacity 0.2s ease,
      text-shadow 0.2s ease;
  }
  .fotos-note-link:hover {
    text-shadow: 0 0 12px color-mix(in srgb, var(--accent) 50%, transparent);
    opacity: 0.85;
  }

  .upload-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    margin-bottom: 72px;
  }
  .upload-left-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 0.92;
    color: var(--text);
    letter-spacing: 0.02em;
  }
  .upload-left-sub {
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 300;
    max-width: 360px;
    margin-top: 16px;
  }
  .upload-right {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .upload-uploader {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  .upload-avisos {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 440px;
    width: 100%;
  }
  .upload-aviso {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    border: 1px solid var(--border);
    background: var(--bg2);
    font-size: 0.72rem;
    line-height: 1.6;
    color: var(--muted);
    font-weight: 300;
  }
  .upload-aviso :global(svg) {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--accent);
  }

  .mark {
    color: var(--color-text);
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .premio-wrap {
      grid-template-columns: 1fr;
      max-width: 760px;
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .fotos-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .upload-grid {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-bottom: 48px;
    }
    .upload-uploader {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
