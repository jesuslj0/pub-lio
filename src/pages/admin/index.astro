        object-fit: cover;
        flex-shrink: 0;
        background: var(--bg);
      }
      .foto-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex: 1;
        min-width: 0;
      }
      .foto-actions {
        display: flex;
        gap: 8px;
      }
      /* Estado ganadora */
      .winner-flag {
        display: none;
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
      }
      .winner-row.is-winner {
        border-color: var(--accent);
      }
      .winner-row.is-winner .winner-flag {
        display: inline;
      }
      /* Historial carteles/premios */
      .active-flag {
        display: none;
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
      }
      .hist-row.is-active {
        border-color: var(--accent);
      }
      .hist-row.is-active .active-flag {
        display: inline;
      }
      .thumb-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        border: 1px dashed var(--border);
      }
      /* Historial de fotos */
      .hist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 10px;
      }
      .hist-foto {
        position: relative;
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 8px;
      }
      .hist-foto-link {
        display: flex;
        flex-direction: column;
        gap: 6px;
        text-decoration: none;
        color: var(--text);
      }
      .hist-foto-del {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
        display: flex;
