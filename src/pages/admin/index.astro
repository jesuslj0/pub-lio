      }
      .estado.rechazada {
        color: var(--red);
      }
      .btn {
        border: none;
        padding: 9px 16px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        color: #fff;
      }
      .btn:disabled {
