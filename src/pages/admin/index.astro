        --muted: var(--color-muted);
        --green: #3ad17a;
        --red: var(--color-accent3);
      }
      html, body {
        overflow-x: hidden;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, sans-serif;
        padding: 32px;
        line-height: 1.5;
        overflow-x: hidden;
      }
      main {
        max-width: 760px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 48px;
        padding: 0;
      }
      /* Login */
      .login-wrap {
        min-height: 80vh;
        display: flex;
        justify-content: center;
