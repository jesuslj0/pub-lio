---
import "../../styles/global.css";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import { getCurrentWeek, getPreviousWeek } from "../../lib/supabase";
import { isAdmin } from "../../lib/adminAuth";
import { Trash2 } from "@lucide/astro";
import type { Foto, Cartel, Premio } from "../../lib/database.types";

export const prerender = false;

// ─── Autenticación por cookie ───
const authed = isAdmin(Astro.cookies);
const loginError = Astro.url.searchParams.get("error") === "1";

// Config pública de Cloudinary para subir la imagen del cartel desde el panel.
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const uploadPreset = import.meta.env.PUBLIC_CLOUDINARY_UPLOAD_PRESET;

// ─── Datos (solo si está autenticado) ───
let pendientes: Foto[] = [];
let aprobadas: Foto[] = [];
let topPasada: Foto[] = [];
let cartelActivo: Cartel | null = null;
let premioActivo: Premio | null = null;
let carteles: Cartel[] = [];
let premios: Premio[] = [];
let historialFotos: Foto[] = [];
let loadError = false;
const semana = getCurrentWeek();
const semanaPasada = getPreviousWeek();

if (authed) {
  try {
    const [pend, aprob, pasada, cartelesRes, premiosRes, fotosRes] = await Promise.all([
      supabaseAdmin
        .from("fotos")
        .select("*")
        .eq("estado", "pendiente")
        .order("created_at", { ascending: false }),
      supabaseAdmin
        .from("fotos")
        .select("*")
        .eq("estado", "aprobada")
        .eq("semana", semana)
        .order("votos_count", { ascending: false }),
      supabaseAdmin
        .from("fotos")
        .select("*")
        .eq("estado", "aprobada")
        .eq("semana", semanaPasada)
        .order("votos_count", { ascending: false })
        .limit(3),
      supabaseAdmin
        .from("carteles")
        .select("*")
        .order("created_at", { ascending: false }),
      supabaseAdmin
        .from("premios")
        .select("*")
        .order("created_at", { ascending: false }),
      supabaseAdmin
        .from("fotos")
        .select("*")
        .order("created_at", { ascending: false })
        .limit(60),
    ]);
    if (pend.error) throw pend.error;
    if (aprob.error) throw aprob.error;
    if (pasada.error) throw pasada.error;
    if (cartelesRes.error) throw cartelesRes.error;
    if (premiosRes.error) throw premiosRes.error;
    if (fotosRes.error) throw fotosRes.error;
    pendientes = pend.data ?? [];
    aprobadas = aprob.data ?? [];
    topPasada = pasada.data ?? [];
    carteles = cartelesRes.data ?? [];
    premios = premiosRes.data ?? [];
    historialFotos = fotosRes.data ?? [];
    premioActivo = premios.find((p) => p.activo) ?? null;
  } catch (err) {
    console.error("[admin] cargar datos", err);
    loadError = true;
  }
}

const fmt = (iso: string) =>
  new Date(iso).toLocaleString("es-ES", {
    day: "2-digit",
    month: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
  });
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin · Lío El Bonillo</title>
  </head>
  <body>
    {
      !authed ? (
        <main class="login-wrap">
          <form class="login-box" method="POST" action="/api/admin/login">
            <span class="tag">Lío El Bonillo</span>
            <h1>Acceso admin</h1>
            <p class="muted">Introduce la clave de administración.</p>
            <input
              type="password"
              name="secret"
              placeholder="Clave de administración"
              autocomplete="current-password"
              required
              autofocus
            />
            {loginError && <p class="error">Clave incorrecta.</p>}
            <button type="submit" class="btn btn-primary">Entrar</button>
          </form>
        </main>
      ) : (
        <main>
          <header class="head">
            <div>
              <h1>Panel de administración</h1>
              <span class="tag">Lío El Bonillo · {semana}</span>
            </div>
            <form method="POST" action="/api/admin/logout">
              <button type="submit" class="btn btn-ghost btn-logout">Cerrar sesión</button>
            </form>
          </header>

          {loadError && <p class="error">No se pudieron cargar las fotos.</p>}

          {/* A) FOTOS PENDIENTES */}
          <section>
            <h2>
              Fotos pendientes <span class="count">{pendientes.length}</span>
            </h2>
            {!loadError && pendientes.length === 0 && (
              <p class="muted">No hay fotos pendientes de revisión.</p>
            )}
            <div class="foto-list">
              {pendientes.map((foto) => (
                <div class="foto-row" data-foto-id={foto.id}>
                  <img src={foto.cloudinary_url} alt="thumbnail" class="thumb" />
                  <div class="foto-info">
                    <strong>{foto.nombre_autor ?? "Anónimo"}</strong>
                    <span class="muted">{fmt(foto.created_at)}</span>
                    <span class="muted small">{foto.semana}</span>
                  </div>
                  <div class="foto-actions">
                    <button class="btn btn-approve" data-accion="aprobar">
                      Aprobar
                    </button>
                    <button class="btn btn-reject" data-accion="rechazar">
                      Rechazar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* B) FOTOS APROBADAS — marcar ganadora */}
          <section>
            <h2>
              Fotos aprobadas (esta semana){" "}
              <span class="count">{aprobadas.length}</span>
            </h2>
            {!loadError && aprobadas.length === 0 && (
              <p class="muted">Aún no hay fotos aprobadas esta semana.</p>
            )}
            <div class="foto-list">
              {aprobadas.map((foto) => (
                <div
                  class:list={["foto-row", "winner-row", { "is-winner": foto.ganadora }]}
                  data-foto-id={foto.id}
                >
                  <img src={foto.cloudinary_url} alt="thumbnail" class="thumb" />
                  <div class="foto-info">
                    <strong>{foto.nombre_autor ?? "Anónimo"}</strong>
                    <span class="muted">{foto.votos_count} votos</span>
                    <span class="winner-flag">🏆 Ganadora</span>
                  </div>
                  <div class="foto-actions">
                    <button
                      class:list={["btn", "btn-winner", foto.ganadora ? "btn-ghost" : "btn-primary"]}
                    >
                      {foto.ganadora ? "Quitar ganadora" : "Marcar ganadora"}
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* B2) TOP SEMANA PASADA — marcar ganadora */}
          <section>
            <h2>
              Top semana pasada ({semanaPasada}){" "}
              <span class="count">{topPasada.length}</span>
            </h2>
            {!loadError && topPasada.length === 0 && (
              <p class="muted">No hay fotos aprobadas de la semana pasada.</p>
            )}
            <div class="foto-list">
              {topPasada.map((foto) => (
                <div
                  class:list={["foto-row", "winner-row", { "is-winner": foto.ganadora }]}
                  data-foto-id={foto.id}
                >
                  <img src={foto.cloudinary_url} alt="thumbnail" class="thumb" />
                  <div class="foto-info">
                    <strong>{foto.nombre_autor ?? "Anónimo"}</strong>
                    <span class="muted">{foto.votos_count} votos</span>
                    <span class="winner-flag">🏆 Ganadora</span>
                  </div>
                  <div class="foto-actions">
                    <button
                      class:list={["btn", "btn-winner", foto.ganadora ? "btn-ghost" : "btn-primary"]}
                    >
                      {foto.ganadora ? "Quitar ganadora" : "Marcar ganadora"}
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* C) CARTELES */}
          <section>
            <div class="section-head">
              <h2>Carteles</h2>
              <button type="button" id="cartel-nuevo-btn" class="btn btn-primary">+ Nuevo cartel</button>
            </div>
            <p class="muted small">
              Puedes mostrar varios carteles a la vez (p. ej. los 2-3 de un finde).
              Marca cuáles se muestran desde el historial de abajo.
            </p>
            <div id="cartel-form-wrap" hidden>
            <div class="section-head form-subhead">
              <h3 id="cartel-titulo">Nuevo cartel</h3>
              <button type="button" id="cartel-cancel" class="btn btn-ghost">
                Cancelar
              </button>
            </div>
            <form
              id="cartel-form"
              class="cartel-form"
              data-id=""
              data-imagen-url=""
              data-media-tipo="imagen"
            >
              <label>
                Título *
                <input name="titulo" type="text" required value="" />
              </label>
              <label>
                Descripción del evento
                <textarea name="subtitulo" rows="4" placeholder="Cuenta de qué va el finde…"></textarea>
              </label>
              <label>
                Imagen o vídeo del cartel
                <span id="cartel-media-hint" class="muted small" hidden>
                  Hay un medio actual. Sube uno nuevo solo si quieres reemplazarlo.
                </span>
                <input id="cartel-imagen" name="imagen" type="file" accept="image/*,video/*" />
              </label>
              <img
                id="cartel-preview"
                class="cartel-preview"
                alt="Vista previa"
                hidden
              />
              <video
                id="cartel-preview-video"
                class="cartel-preview"
                muted
                playsinline
                controls
                hidden
              ></video>
              <div class="row">
                <label>
                  Fecha inicio
                  <input name="fecha_inicio" type="date" value="" />
                </label>
                <label>
                  Fecha fin
                  <input name="fecha_fin" type="date" value="" />
                </label>
              </div>
              <label class="checkbox">
                <input name="activo" type="checkbox" checked />
                Mostrar este cartel en la web (pueden mostrarse varios a la vez)
              </label>
              <button type="submit" class="btn btn-primary">
                Guardar cartel
              </button>
              <p id="cartel-msg" class="msg" />
            </form>
            </div>
          </section>

          {/* C2) HISTORIAL DE CARTELES */}
          <section>
            <h2>
              Historial de carteles <span class="count">{carteles.length}</span>
            </h2>
            {carteles.length === 0 && (
              <p class="muted">Aún no hay carteles.</p>
            )}
            <div class="foto-list">
              {carteles.map((c) => (
                <div
                  class:list={["foto-row", "hist-cartel", { "is-active": c.activo }]}
                  data-id={c.id}
                  data-json={JSON.stringify({
                    id: c.id,
                    titulo: c.titulo,
                    subtitulo: c.subtitulo,
                    imagen_url: c.imagen_url,
                    media_tipo: c.media_tipo,
                    fecha_inicio: c.fecha_inicio,
                    fecha_fin: c.fecha_fin,
                    activo: c.activo,
                  })}
                >
                  {c.imagen_url ? (
                    c.media_tipo === "video" ? (
                      <video src={c.imagen_url} class="thumb" muted playsinline />
                    ) : (
                      <img src={c.imagen_url} alt="thumbnail" class="thumb" />
                    )
                  ) : (
                    <div class="thumb thumb-empty">—</div>
                  )}
                  <div class="foto-info">
                    <strong>{c.titulo}</strong>
                    <span class="muted small">{fmt(c.created_at)}</span>
                    <span class="active-flag">● Mostrándose</span>
                  </div>
                  <div class="foto-actions">
                    <button class="btn btn-ghost" data-accion="editar">
                      Editar
                    </button>
                    {c.activo ? (
                      <button class="btn btn-ghost" data-accion="desactivar">
                        Quitar
                      </button>
                    ) : (
                      <button class="btn btn-primary" data-accion="activar">
                        Mostrar
                      </button>
                    )}
                    <button class="btn btn-reject" data-accion="eliminar">
                      Eliminar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* D) PREMIO SEMANAL */}
          <section>
            <div class="section-head">
              <h2 id="premio-titulo">{premioActivo ? "Editar premio activo" : "Nuevo premio semanal"}</h2>
              {premioActivo && (
                <button type="button" id="premio-nuevo" class="btn btn-ghost">
                  + Crear nuevo
                </button>
              )}
            </div>
            <form
              id="premio-form"
              class="cartel-form"
              data-id={premioActivo?.id ?? ""}
              data-imagen-url={premioActivo?.imagen_url ?? ""}
            >
              <label>
                Título *
                <input name="titulo" type="text" required value={premioActivo?.titulo ?? ""} />
              </label>
              <label>
                Descripción
                <textarea name="descripcion" rows="3">{premioActivo?.descripcion ?? ""}</textarea>
              </label>
              <label>
                Imagen del premio
                {premioActivo?.imagen_url && (
                  <span class="muted small">
                    Hay una imagen actual. Sube una nueva solo si quieres reemplazarla.
                  </span>
                )}
                <input id="premio-imagen" name="imagen" type="file" accept="image/*" />
              </label>
              <img
                id="premio-preview"
                class="cartel-preview"
                alt="Vista previa"
                src={premioActivo?.imagen_url ?? undefined}
                hidden={!premioActivo?.imagen_url}
              />
              <label>
                Válido hasta
                <input name="valido_hasta" type="date" value={premioActivo?.valido_hasta ?? ""} />
              </label>
              <label class="checkbox">
                <input name="activo" type="checkbox" checked={premioActivo?.activo ?? true} />
                Activar este premio (desactiva los demás)
              </label>
              <button type="submit" class="btn btn-primary">
                {premioActivo ? "Actualizar premio" : "Guardar premio"}
              </button>
              <p id="premio-msg" class="msg" />
            </form>
          </section>

          {/* D2) HISTORIAL DE PREMIOS */}
          <section>
            <h2>
              Historial de premios <span class="count">{premios.length}</span>
            </h2>
            {premios.length === 0 && <p class="muted">Aún no hay premios.</p>}
            <div class="foto-list">
              {premios.map((p) => (
                <div
                  class:list={["foto-row", "hist-row", { "is-active": p.activo }]}
                  data-id={p.id}
                  data-tipo="premio"
                >
                  {p.imagen_url ? (
                    <img src={p.imagen_url} alt="thumbnail" class="thumb" />
                  ) : (
                    <div class="thumb thumb-empty">—</div>
                  )}
                  <div class="foto-info">
                    <strong>{p.titulo}</strong>
                    <span class="muted small">{fmt(p.created_at)}</span>
                    <span class="active-flag">● Activo</span>
                  </div>
                  <div class="foto-actions">
                    {!p.activo && (
                      <button class="btn btn-primary" data-accion="activar">
                        Activar
                      </button>
                    )}
                    <button class="btn btn-reject" data-accion="eliminar">
                      Eliminar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* E) HISTORIAL DE FOTOS SUBIDAS */}
          <section>
            <h2>
              Historial de fotos <span class="count">{historialFotos.length}</span>
            </h2>
            {historialFotos.length === 0 && (
              <p class="muted">Aún no hay fotos subidas.</p>
            )}
            <div class="hist-grid">
              {historialFotos.map((foto) => (
                <div class="hist-foto" data-foto-id={foto.id}>
                  <button
                    type="button"
                    class="hist-foto-del"
                    data-accion="borrar-foto"
                    aria-label="Borrar foto"
                    title="Borrar foto"
                  >
                    <Trash2 size={15} stroke-width={1.5} />
                  </button>
                  <a
                    class="hist-foto-link"
                    href={foto.cloudinary_url}
                    target="_blank"
                    rel="noopener"
                  >
                    <img src={foto.cloudinary_url} alt="foto" loading="lazy" />
                    <div class="hist-foto-meta">
                      <span class:list={["estado", foto.estado]}>{foto.estado}</span>
                      <span class="muted small">{foto.votos_count} ★</span>
                    </div>
                    <span class="muted small hist-foto-sub">
                      {foto.nombre_autor ?? "Anónimo"} · {foto.semana}
                      {foto.ganadora ? " · 🏆" : ""}
                    </span>
                  </a>
                  <div class="hist-foto-mod">
                    {foto.estado !== "aprobada" && (
                      <button class="btn btn-approve btn-sm" data-accion="aprobar">
                        Aprobar
                      </button>
                    )}
                    {foto.estado !== "rechazada" && (
                      <button class="btn btn-reject btn-sm" data-accion="rechazar">
                        Rechazar
                      </button>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* Modal de confirmación reutilizable */}
          <div id="del-modal" class="modal-overlay" hidden>
            <div class="modal-box" role="dialog" aria-modal="true">
              <h3 id="del-title">Confirmar</h3>
              <p class="muted" id="del-text">¿Seguro que quieres continuar?</p>
              <div class="modal-actions">
                <button type="button" id="del-cancel" class="btn btn-ghost">
                  Cancelar
                </button>
                <button type="button" id="del-confirm" class="btn btn-reject">
                  Confirmar
                </button>
              </div>
            </div>
          </div>
        </main>
      )
    }

    {
      authed && (
        <script is:inline define:vars={{ cloudName, uploadPreset }}>
          {/* Las llamadas usan la cookie httpOnly automáticamente; no hay secreto en el cliente. */}
          // ─── Moderación de fotos pendientes ───
          document
            .querySelectorAll(".foto-row:not(.winner-row):not(.hist-row)")
            .forEach((row) => {
              row.querySelectorAll(".btn").forEach((btn) => {
                btn.addEventListener("click", async () => {
                  const fotoId = row.getAttribute("data-foto-id");
                  const accion = btn.getAttribute("data-accion");
                  row.querySelectorAll(".btn").forEach((b) => (b.disabled = true));
                  try {
                    const res = await fetch("/api/admin/moderate", {
                      method: "POST",
                      headers: { "Content-Type": "application/json" },
                      body: JSON.stringify({ fotoId, accion }),
                    });
                    const data = await res.json();
                    if (data.success) row.remove();
                    else {
                      alert("Error: " + (data.error || "no se pudo procesar"));
                      row
                        .querySelectorAll(".btn")
                        .forEach((b) => (b.disabled = false));
                    }
                  } catch {
                    alert("Error de red");
                    row
                      .querySelectorAll(".btn")
                      .forEach((b) => (b.disabled = false));
                  }
                });
              });
            });

          // ─── Marcar / quitar ganadora (toggle) ───
          function pintarBotonGanadora(btn, esGanadora) {
            btn.textContent = esGanadora ? "Quitar ganadora" : "Marcar ganadora";
            btn.classList.toggle("btn-ghost", esGanadora);
            btn.classList.toggle("btn-primary", !esGanadora);
          }
          document.querySelectorAll(".btn-winner").forEach((btn) => {
            btn.addEventListener("click", async () => {
              const row = btn.closest(".foto-row");
              const fotoId = row.getAttribute("data-foto-id");
              const marcar = !row.classList.contains("is-winner");
              btn.disabled = true;
              try {
                const res = await fetch("/api/admin/set-winner", {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({ fotoId, ganadora: marcar }),
                });
                const data = await res.json();
                if (data.success) {
                  if (marcar) {
                    // Solo una ganadora por semana: resetea el resto en la UI,
                    // pero acotado a la sección de esta semana (hay dos bloques:
                    // semana actual y semana pasada, cada uno con su ganadora).
                    const ambito = row.closest("section") || document;
                    ambito.querySelectorAll(".winner-row").forEach((r) => {
                      r.classList.remove("is-winner");
                      const b = r.querySelector(".btn-winner");
                      if (b) pintarBotonGanadora(b, false);
                    });
                    row.classList.add("is-winner");
                  } else {
                    row.classList.remove("is-winner");
                  }
                  pintarBotonGanadora(btn, marcar);
                } else {
                  alert("Error: " + (data.error || "no se pudo actualizar"));
                }
              } catch {
                alert("Error de red");
              } finally {
                btn.disabled = false;
              }
            });
          });

          // ─── Vista previa de la imagen/vídeo del cartel ───
          const imagenInput = document.getElementById("cartel-imagen");
          const preview = document.getElementById("cartel-preview");
          const previewVideo = document.getElementById("cartel-preview-video");
          const cartelMediaHint = document.getElementById("cartel-media-hint");
          const cartelCancel = document.getElementById("cartel-cancel");
          const cartelFormWrap = document.getElementById("cartel-form-wrap");
          function limpiarPreviews() {
            preview.hidden = true;
            preview.removeAttribute("src");
            previewVideo.hidden = true;
            previewVideo.removeAttribute("src");
          }
          imagenInput?.addEventListener("change", () => {
            limpiarPreviews();
            const file = imagenInput.files && imagenInput.files[0];
            if (!file) return;
            const url = URL.createObjectURL(file);
            if (file.type.startsWith("video/")) {
              previewVideo.src = url;
              previewVideo.hidden = false;
            } else {
              preview.src = url;
              preview.hidden = false;
            }
          });

          // ─── Formulario de cartel ───
          const form = document.getElementById("cartel-form");
          const msg = document.getElementById("cartel-msg");
          form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const fd = new FormData(form);
            msg.className = "msg";

            try {
              // Si no se sube un medio nuevo, se conserva el actual (edición).
              let imagenUrl = form.dataset.imagenUrl || null;
              let mediaTipo = form.dataset.mediaTipo || "imagen";
              const file = fd.get("imagen");
              if (file && file.size > 0) {
                const esVideo = file.type.startsWith("video/");
                msg.textContent = esVideo
                  ? "Subiendo vídeo..."
                  : "Subiendo imagen...";
                const cloudData = new FormData();
                cloudData.append("file", file);
                cloudData.append("upload_preset", uploadPreset);
                // Endpoint /auto/ acepta imagen y vídeo (auto-detección).
                const up = await fetch(
                  "https://api.cloudinary.com/v1_1/" + cloudName + "/auto/upload",
                  { method: "POST", body: cloudData },
                );
                if (!up.ok) throw new Error("cloudinary");
                const upJson = await up.json();
                imagenUrl = upJson.secure_url;
                mediaTipo =
                  upJson.resource_type === "video" || esVideo
                    ? "video"
                    : "imagen";
              }

              const payload = {
                id: form.dataset.id || null,
                titulo: fd.get("titulo"),
                subtitulo: fd.get("subtitulo"),
                imagen_url: imagenUrl,
                media_tipo: mediaTipo,
                fecha_inicio: fd.get("fecha_inicio"),
                fecha_fin: fd.get("fecha_fin"),
                activo: fd.get("activo") === "on",
              };
              msg.textContent = "Guardando...";
              const res = await fetch("/api/admin/cartel", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
              });
              const data = await res.json();
              if (data.success) {
                msg.textContent = form.dataset.id
                  ? "✓ Cartel actualizado"
                  : "✓ Cartel guardado";
                msg.className = "msg ok";
                setTimeout(() => location.reload(), 700);
              } else {
                msg.textContent =
                  "Error: " + (data.error || "no se pudo guardar");
                msg.className = "msg err";
              }
            } catch {
              msg.textContent = "Error de red";
              msg.className = "msg err";
            }
          });

          // ─── Reset del formulario de cartel a modo "Nuevo" ───
          function resetCartelForm() {
            form.querySelectorAll("input, textarea").forEach((el) => {
              if (el.type === "checkbox") el.checked = true;
              else el.value = "";
            });
            form.dataset.id = "";
            form.dataset.imagenUrl = "";
            form.dataset.mediaTipo = "imagen";
            limpiarPreviews();
            if (cartelMediaHint) cartelMediaHint.hidden = true;
            const t = document.getElementById("cartel-titulo");
            if (t) t.textContent = "Nuevo cartel";
            const submitBtn = form.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.textContent = "Guardar cartel";
            if (cartelFormWrap) cartelFormWrap.hidden = true;
            msg.textContent = "";
            msg.className = "msg";
          }

          // ─── Cargar un cartel existente en el formulario para editarlo ───
          function cargarCartelEnFormulario(data) {
            form.querySelector('[name="titulo"]').value = data.titulo || "";
            form.querySelector('[name="subtitulo"]').value = data.subtitulo || "";
            form.querySelector('[name="fecha_inicio"]').value =
              data.fecha_inicio || "";
            form.querySelector('[name="fecha_fin"]').value = data.fecha_fin || "";
            form.querySelector('[name="activo"]').checked = !!data.activo;
            form.dataset.id = data.id || "";
            form.dataset.imagenUrl = data.imagen_url || "";
            form.dataset.mediaTipo = data.media_tipo || "imagen";
            limpiarPreviews();
            if (data.imagen_url) {
              if (data.media_tipo === "video") {
                previewVideo.src = data.imagen_url;
                previewVideo.hidden = false;
              } else {
                preview.src = data.imagen_url;
                preview.hidden = false;
              }
              if (cartelMediaHint) cartelMediaHint.hidden = false;
            } else if (cartelMediaHint) {
              cartelMediaHint.hidden = true;
            }
            const t = document.getElementById("cartel-titulo");
            if (t) t.textContent = "Editar cartel";
            const submitBtn = form.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.textContent = "Actualizar cartel";
            if (cartelFormWrap) cartelFormWrap.hidden = false;
            msg.textContent = "";
            msg.className = "msg";
            (cartelFormWrap || form).scrollIntoView({ behavior: "smooth", block: "start" });
            form.querySelector('[name="titulo"]')?.focus();
          }

          cartelCancel?.addEventListener("click", resetCartelForm);

          document.getElementById("cartel-nuevo-btn")?.addEventListener("click", () => {
            resetCartelForm();
            if (cartelFormWrap) cartelFormWrap.hidden = false;
            cartelFormWrap?.scrollIntoView({ behavior: "smooth", block: "start" });
            form?.querySelector('[name="titulo"]')?.focus();
          });

          // ─── Historial de carteles: editar / mostrar / quitar / eliminar ───
          document.querySelectorAll(".hist-cartel").forEach((row) => {
            const id = row.getAttribute("data-id");
            // Llama al endpoint de carteles (PATCH = mostrar/ocultar, DELETE = borrar).
            async function ejecutar(method, body) {
              row.querySelectorAll(".btn").forEach((b) => (b.disabled = true));
              try {
                const res = await fetch("/api/admin/cartel", {
                  method,
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify(body),
                });
                const data = await res.json();
                if (data.success) {
                  location.reload();
                  return true;
                }
                alert("Error: " + (data.error || "no se pudo procesar"));
              } catch {
                alert("Error de red");
              }
              row.querySelectorAll(".btn").forEach((b) => (b.disabled = false));
              return false;
            }
            row.querySelectorAll(".btn").forEach((btn) => {
              btn.addEventListener("click", () => {
                const accion = btn.getAttribute("data-accion");
                if (accion === "editar") {
                  try {
                    cargarCartelEnFormulario(
                      JSON.parse(row.getAttribute("data-json")),
                    );
                  } catch {
                    alert("No se pudo cargar el cartel para editar");
                  }
                } else if (accion === "activar") {
                  ejecutar("PATCH", { id, activo: true });
                } else if (accion === "desactivar") {
                  ejecutar("PATCH", { id, activo: false });
                } else if (accion === "eliminar") {
                  pedirConfirmacion({
                    titulo: "Eliminar cartel",
                    texto:
                      "Esta acción elimina el cartel definitivamente (también su imagen en Cloudinary) y no se puede deshacer. ¿Continuar?",
                    confirmar: "Eliminar definitivamente",
                    accion: () => ejecutar("DELETE", { id }),
                  });
                }
              });
            });
          });

          // ─── Vista previa de la imagen del premio ───
          const premioImagenInput = document.getElementById("premio-imagen");
          const premioPreview = document.getElementById("premio-preview");
          premioImagenInput?.addEventListener("change", () => {
            const file = premioImagenInput.files && premioImagenInput.files[0];
            if (file) {
              premioPreview.src = URL.createObjectURL(file);
              premioPreview.hidden = false;
            } else {
              premioPreview.hidden = true;
              premioPreview.removeAttribute("src");
            }
          });

          // ─── Formulario de premio semanal ───
          const premioForm = document.getElementById("premio-form");
          const premioMsg = document.getElementById("premio-msg");
          premioForm?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const fd = new FormData(premioForm);
            premioMsg.className = "msg";

            try {
              // Si no se sube una imagen nueva, se conserva la actual (edición).
              let imagenUrl = premioForm.dataset.imagenUrl || null;
              const file = fd.get("imagen");
              if (file && file.size > 0) {
                premioMsg.textContent = "Subiendo imagen...";
                const cloudData = new FormData();
                cloudData.append("file", file);
                cloudData.append("upload_preset", uploadPreset);
                const up = await fetch(
                  "https://api.cloudinary.com/v1_1/" + cloudName + "/image/upload",
                  { method: "POST", body: cloudData },
                );
                if (!up.ok) throw new Error("cloudinary");
                const upJson = await up.json();
                imagenUrl = upJson.secure_url;
              }

              const payload = {
                id: premioForm.dataset.id || null,
                titulo: fd.get("titulo"),
                descripcion: fd.get("descripcion"),
                imagen_url: imagenUrl,
                valido_hasta: fd.get("valido_hasta"),
                activo: fd.get("activo") === "on",
              };
              premioMsg.textContent = "Guardando...";
              const res = await fetch("/api/admin/premio", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
              });
              const data = await res.json();
              if (data.success) {
                premioMsg.textContent = premioForm.dataset.id
                  ? "✓ Premio actualizado"
                  : "✓ Premio guardado";
                premioMsg.className = "msg ok";
                setTimeout(() => location.reload(), 700);
              } else {
                premioMsg.textContent =
                  "Error: " + (data.error || "no se pudo guardar");
                premioMsg.className = "msg err";
              }
            } catch {
              premioMsg.textContent = "Error de red";
              premioMsg.className = "msg err";
            }
          });

          // ─── Botón "Crear nuevo" premio: vacía el form y pasa a modo creación ───
          document.getElementById("premio-nuevo")?.addEventListener("click", () => {
            premioForm.querySelectorAll("input, textarea").forEach((el) => {
              if (el.type === "checkbox") el.checked = true;
              else el.value = "";
            });
            premioForm.dataset.id = "";
            premioForm.dataset.imagenUrl = "";
            premioPreview.hidden = true;
            premioPreview.removeAttribute("src");
            const t = document.getElementById("premio-titulo");
            if (t) t.textContent = "Nuevo premio semanal";
            const submitBtn = premioForm.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.textContent = "Guardar premio";
            premioMsg.textContent = "";
            premioMsg.className = "msg";
            premioForm.querySelector('[name="titulo"]')?.focus();
          });

          // ─── Historial de carteles/premios: activar / eliminar ───
          document.querySelectorAll(".hist-row").forEach((row) => {
            const tipo = row.getAttribute("data-tipo"); // 'cartel' | 'premio'
            const id = row.getAttribute("data-id");
            const endpoint =
              tipo === "premio" ? "/api/admin/premio" : "/api/admin/cartel";
            const nombre = tipo === "premio" ? "premio" : "cartel";
            // Ejecuta activar/eliminar contra el endpoint correspondiente.
            async function ejecutar(accion) {
              row.querySelectorAll(".btn").forEach((b) => (b.disabled = true));
              try {
                const res = await fetch(endpoint, {
                  method: accion === "eliminar" ? "DELETE" : "PATCH",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({ id }),
                });
                const data = await res.json();
                if (data.success) {
                  location.reload();
                  return true;
                }
                alert("Error: " + (data.error || "no se pudo procesar"));
                row.querySelectorAll(".btn").forEach((b) => (b.disabled = false));
                return false;
              } catch {
                alert("Error de red");
                row.querySelectorAll(".btn").forEach((b) => (b.disabled = false));
                return false;
              }
            }
            row.querySelectorAll(".btn").forEach((btn) => {
              btn.addEventListener("click", () => {
                const accion = btn.getAttribute("data-accion");
                if (accion === "eliminar") {
                  pedirConfirmacion({
                    titulo: "Eliminar " + nombre,
                    texto:
                      "Esta acción elimina el " +
                      nombre +
                      " definitivamente (también su imagen en Cloudinary) y no se puede deshacer. ¿Continuar?",
                    confirmar: "Eliminar definitivamente",
                    accion: () => ejecutar("eliminar"),
                  });
                } else {
                  ejecutar(accion);
                }
              });
            });
          });

          // ─── Modal de confirmación reutilizable ───
          const delModal = document.getElementById("del-modal");
          const delTitle = document.getElementById("del-title");
          const delText = document.getElementById("del-text");
          const delConfirm = document.getElementById("del-confirm");
          const delCancel = document.getElementById("del-cancel");
          let onConfirm = null; // callback async en espera de confirmación
          const confirmLabelDefault = "Confirmar";

          function cerrarModal() {
            delModal.hidden = true;
            onConfirm = null;
            delConfirm.disabled = false;
            delConfirm.textContent = confirmLabelDefault;
          }

          // Abre el modal con textos a medida y guarda el callback a ejecutar.
          function pedirConfirmacion({ titulo, texto, confirmar, accion }) {
            delTitle.textContent = titulo;
            delText.textContent = texto;
            delConfirm.textContent = confirmar || confirmLabelDefault;
            delConfirm.dataset.label = confirmar || confirmLabelDefault;
            onConfirm = accion;
            delModal.hidden = false;
          }

          delCancel?.addEventListener("click", cerrarModal);
          delModal?.addEventListener("click", (e) => {
            if (e.target === delModal) cerrarModal();
          });

          delConfirm?.addEventListener("click", async () => {
            if (!onConfirm) return;
            const label = delConfirm.dataset.label || confirmLabelDefault;
            delConfirm.disabled = true;
            delConfirm.textContent = "Procesando...";
            try {
              const ok = await onConfirm();
              if (ok) cerrarModal();
              else {
                delConfirm.disabled = false;
                delConfirm.textContent = label;
              }
            } catch {
              alert("Error de red");
              delConfirm.disabled = false;
              delConfirm.textContent = label;
            }
          });

          // ─── Borrado definitivo de fotos ───
          document
            .querySelectorAll('.hist-foto-del[data-accion="borrar-foto"]')
            .forEach((btn) => {
              btn.addEventListener("click", () => {
                const tarjeta = btn.closest(".hist-foto");
                const fotoId = tarjeta.getAttribute("data-foto-id");
                pedirConfirmacion({
                  titulo: "Borrar foto",
                  texto:
                    "Esta acción elimina la foto definitivamente (también de Cloudinary) y no se puede deshacer. ¿Continuar?",
                  confirmar: "Borrar definitivamente",
                  accion: async () => {
                    const res = await fetch("/api/admin/delete-photo", {
                      method: "DELETE",
                      headers: { "Content-Type": "application/json" },
                      body: JSON.stringify({ fotoId }),
                    });
                    const data = await res.json();
                    if (data.success) {
                      tarjeta.remove();
                      return true;
                    }
                    alert("Error: " + (data.error || "no se pudo borrar"));
                    return false;
                  },
                });
              });
            });

          // ─── Re-moderar fotos desde el historial (aprobar / rechazar) ───
          document.querySelectorAll(".hist-foto-mod").forEach((cont) => {
            const tarjeta = cont.closest(".hist-foto");
            const fotoId = tarjeta.getAttribute("data-foto-id");
            const estadoEl = tarjeta.querySelector(".estado");
            cont.querySelectorAll(".btn").forEach((btn) => {
              btn.addEventListener("click", async () => {
                const accion = btn.getAttribute("data-accion");
                cont.querySelectorAll(".btn").forEach((b) => (b.disabled = true));
                try {
                  const res = await fetch("/api/admin/moderate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ fotoId, accion }),
                  });
                  const data = await res.json();
                  if (data.success) {
                    const nuevoEstado =
                      accion === "aprobar" ? "aprobada" : "rechazada";
                    if (estadoEl) {
                      estadoEl.textContent = nuevoEstado;
                      estadoEl.className = "estado " + nuevoEstado;
                    }
                    // Muestra solo la acción contraria a la actual.
                    cont.querySelectorAll(".btn").forEach((b) => {
                      const a = b.getAttribute("data-accion");
                      b.hidden =
                        (nuevoEstado === "aprobada" && a === "aprobar") ||
                        (nuevoEstado === "rechazada" && a === "rechazar");
                      b.disabled = false;
                    });
                  } else {
                    alert("Error: " + (data.error || "no se pudo procesar"));
                    cont
                      .querySelectorAll(".btn")
                      .forEach((b) => (b.disabled = false));
                  }
                } catch {
                  alert("Error de red");
                  cont
                    .querySelectorAll(".btn")
                    .forEach((b) => (b.disabled = false));
                }
              });
            });
          });
        </script>
      )
    }

    <style>
      :root {
        --bg: var(--color-bg);
        --surface: var(--color-surface);
        --border: rgba(255, 255, 255, 0.1);
