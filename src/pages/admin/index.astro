        cursor: default;
      }
      .btn-approve {
        background: var(--green);
        color: #04140a;
      }
      .btn-reject {
        background: var(--red);
      }
      .btn-primary {
        background: var(--accent);
        color: var(--bg);
      }
      .btn-ghost {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--muted);
      }
      .btn-logout {
        padding: 6px 12px;
        font-size: 0.7rem;
        white-space: nowrap;
        align-self: flex-start;
      }
      .cartel-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 24px;
      }
      .cartel-form .btn-primary {
        align-self: flex-start;
      }
      .cartel-preview {
        max-width: 240px;
        border: 1px solid var(--border);
        object-fit: cover;
      }
      label {
        display: flex;
        flex-direction: column;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--muted);
      }
      label.checkbox {
        flex-direction: row;
        align-items: center;
        gap: 10px;
        color: var(--text);
      }
      input[type="text"],
      input[type="url"],
      input[type="date"],
      textarea {
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 10px 12px;
        font-size: 0.9rem;
      }
      textarea {
        font-family: inherit;
        resize: vertical;
      }
      .row {
        display: flex;
        gap: 16px;
      }
      .row label {
        flex: 1;
      }
      .msg {
        font-size: 0.85rem;
        min-height: 1.2em;
      }
      .msg.ok {
        color: var(--green);
      }
      .msg.err {
        color: var(--red);
      }
      /* Modal de confirmación */
      .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: flex;
