---
import "../../styles/global.css";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import { getCurrentWeek } from "../../lib/supabase";
import { isAdmin } from "../../lib/adminAuth";
import type { Foto, Cartel, Premio } from "../../lib/database.types";

export const prerender = false;

// ─── Autenticación por cookie ───
const authed = isAdmin(Astro.cookies);
const loginError = Astro.url.searchParams.get("error") === "1";

// Config pública de Cloudinary para subir la imagen del cartel desde el panel.
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const uploadPreset = import.meta.env.PUBLIC_CLOUDINARY_UPLOAD_PRESET;

// ─── Datos (solo si está autenticado) ───
let pendientes: Foto[] = [];
let aprobadas: Foto[] = [];
let cartelActivo: Cartel | null = null;
let premioActivo: Premio | null = null;
let carteles: Cartel[] = [];
let premios: Premio[] = [];
let historialFotos: Foto[] = [];
let loadError = false;
const semana = getCurrentWeek();

if (authed) {
  try {
    const [pend, aprob, cartelesRes, premiosRes, fotosRes] = await Promise.all([
      supabaseAdmin
        .from("fotos")
        .select("*")
        .eq("estado", "pendiente")
        .order("created_at", { ascending: false }),
      supabaseAdmin
        .from("fotos")
        .select("*")
        .eq("estado", "aprobada")
        .eq("semana", semana)
        .order("votos_count", { ascending: false }),
      supabaseAdmin
        .from("carteles")
        .select("*")
        .order("created_at", { ascending: false }),
      supabaseAdmin
        .from("premios")
        .select("*")
        .order("created_at", { ascending: false }),
      supabaseAdmin
        .from("fotos")
        .select("*")
        .order("created_at", { ascending: false })
        .limit(60),
    ]);
    if (pend.error) throw pend.error;
    if (aprob.error) throw aprob.error;
    if (cartelesRes.error) throw cartelesRes.error;
    if (premiosRes.error) throw premiosRes.error;
    if (fotosRes.error) throw fotosRes.error;
    pendientes = pend.data ?? [];
    aprobadas = aprob.data ?? [];
    carteles = cartelesRes.data ?? [];
    premios = premiosRes.data ?? [];
    historialFotos = fotosRes.data ?? [];
    cartelActivo = carteles.find((c) => c.activo) ?? null;
    premioActivo = premios.find((p) => p.activo) ?? null;
  } catch (err) {
    console.error("[admin] cargar datos", err);
    loadError = true;
  }
}

const fmt = (iso: string) =>
  new Date(iso).toLocaleString("es-ES", {
    day: "2-digit",
    month: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
  });
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin · Lío El Bonillo</title>
  </head>
  <body>
    {
      !authed ? (
        <main class="login-wrap">
          <form class="login-box" method="POST" action="/api/admin/login">
            <span class="tag">Lío El Bonillo</span>
            <h1>Acceso admin</h1>
            <p class="muted">Introduce la clave de administración.</p>
            <input
              type="password"
              name="secret"
              placeholder="Clave de administración"
              autocomplete="current-password"
              required
              autofocus
            />
            {loginError && <p class="error">Clave incorrecta.</p>}
            <button type="submit" class="btn btn-primary">Entrar</button>
          </form>
        </main>
      ) : (
        <main>
          <header class="head">
            <div>
              <h1>Panel de administración</h1>
              <span class="tag">Lío El Bonillo · {semana}</span>
            </div>
            <form method="POST" action="/api/admin/logout">
              <button type="submit" class="btn btn-ghost">Cerrar sesión</button>
            </form>
          </header>

          {loadError && <p class="error">No se pudieron cargar las fotos.</p>}

          {/* A) FOTOS PENDIENTES */}
          <section>
            <h2>
              Fotos pendientes <span class="count">{pendientes.length}</span>
            </h2>
            {!loadError && pendientes.length === 0 && (
              <p class="muted">No hay fotos pendientes de revisión.</p>
            )}
            <div class="foto-list">
              {pendientes.map((foto) => (
                <div class="foto-row" data-foto-id={foto.id}>
                  <img src={foto.cloudinary_url} alt="thumbnail" class="thumb" />
                  <div class="foto-info">
                    <strong>{foto.nombre_autor ?? "Anónimo"}</strong>
                    <span class="muted">{fmt(foto.created_at)}</span>
                    <span class="muted small">{foto.semana}</span>
                  </div>
                  <div class="foto-actions">
                    <button class="btn btn-approve" data-accion="aprobar">
                      Aprobar
                    </button>
                    <button class="btn btn-reject" data-accion="rechazar">
                      Rechazar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* B) FOTOS APROBADAS — marcar ganadora */}
          <section>
            <h2>
              Fotos aprobadas (esta semana){" "}
              <span class="count">{aprobadas.length}</span>
            </h2>
            {!loadError && aprobadas.length === 0 && (
              <p class="muted">Aún no hay fotos aprobadas esta semana.</p>
            )}
            <div class="foto-list">
              {aprobadas.map((foto) => (
                <div
                  class:list={["foto-row", "winner-row", { "is-winner": foto.ganadora }]}
                  data-foto-id={foto.id}
                >
                  <img src={foto.cloudinary_url} alt="thumbnail" class="thumb" />
                  <div class="foto-info">
                    <strong>{foto.nombre_autor ?? "Anónimo"}</strong>
                    <span class="muted">{foto.votos_count} votos</span>
                    <span class="winner-flag">🏆 Ganadora</span>
                  </div>
                  <div class="foto-actions">
                    <button
                      class:list={["btn", "btn-winner", foto.ganadora ? "btn-ghost" : "btn-primary"]}
                    >
                      {foto.ganadora ? "Quitar ganadora" : "Marcar ganadora"}
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* C) CARTELES */}
          <section>
            <div class="section-head">
              <h2 id="cartel-titulo">{cartelActivo ? "Editar cartel activo" : "Nuevo cartel"}</h2>
              {cartelActivo && (
                <button type="button" id="cartel-nuevo" class="btn btn-ghost">
                  + Crear nuevo
                </button>
              )}
            </div>
            <form
              id="cartel-form"
              class="cartel-form"
              data-id={cartelActivo?.id ?? ""}
              data-imagen-url={cartelActivo?.imagen_url ?? ""}
              data-media-tipo={cartelActivo?.media_tipo ?? "imagen"}
            >
              <label>
                Título *
                <input name="titulo" type="text" required value={cartelActivo?.titulo ?? ""} />
              </label>
              <label>
                Descripción del evento
                <textarea name="subtitulo" rows="4" placeholder="Cuenta de qué va el finde…">{cartelActivo?.subtitulo ?? ""}</textarea>
              </label>
              <label>
                Imagen o vídeo del cartel
                {cartelActivo?.imagen_url && (
                  <span class="muted small">
                    Hay un medio actual. Sube uno nuevo solo si quieres reemplazarlo.
                  </span>
                )}
                <input id="cartel-imagen" name="imagen" type="file" accept="image/*,video/*" />
              </label>
              <img
                id="cartel-preview"
                class="cartel-preview"
                alt="Vista previa"
                src={cartelActivo?.media_tipo !== "video" ? (cartelActivo?.imagen_url ?? undefined) : undefined}
                hidden={!(cartelActivo?.imagen_url && cartelActivo?.media_tipo !== "video")}
              />
              <video
                id="cartel-preview-video"
                class="cartel-preview"
                muted
                playsinline
                controls
                src={cartelActivo?.media_tipo === "video" ? (cartelActivo?.imagen_url ?? undefined) : undefined}
                hidden={!(cartelActivo?.imagen_url && cartelActivo?.media_tipo === "video")}
              ></video>
              <div class="row">
                <label>
                  Fecha inicio
                  <input name="fecha_inicio" type="date" value={cartelActivo?.fecha_inicio ?? ""} />
                </label>
                <label>
                  Fecha fin
                  <input name="fecha_fin" type="date" value={cartelActivo?.fecha_fin ?? ""} />
                </label>
              </div>
              <label class="checkbox">
                <input name="activo" type="checkbox" checked={cartelActivo?.activo ?? true} />
                Activar este cartel (desactiva los demás)
              </label>
              <button type="submit" class="btn btn-primary">
                {cartelActivo ? "Actualizar cartel" : "Guardar cartel"}
              </button>
              <p id="cartel-msg" class="msg" />
            </form>
          </section>

          {/* C2) HISTORIAL DE CARTELES */}
          <section>
            <h2>
              Historial de carteles <span class="count">{carteles.length}</span>
            </h2>
            {carteles.length === 0 && (
              <p class="muted">Aún no hay carteles.</p>
            )}
            <div class="foto-list">
              {carteles.map((c) => (
                <div
                  class:list={["foto-row", "hist-row", { "is-active": c.activo }]}
                  data-id={c.id}
                  data-tipo="cartel"
                >
                  {c.imagen_url ? (
                    c.media_tipo === "video" ? (
                      <video src={c.imagen_url} class="thumb" muted playsinline />
                    ) : (
                      <img src={c.imagen_url} alt="thumbnail" class="thumb" />
                    )
                  ) : (
                    <div class="thumb thumb-empty">—</div>
                  )}
                  <div class="foto-info">
                    <strong>{c.titulo}</strong>
                    <span class="muted small">{fmt(c.created_at)}</span>
                    <span class="active-flag">● Activo</span>
                  </div>
                  <div class="foto-actions">
                    {!c.activo && (
                      <button class="btn btn-primary" data-accion="activar">
                        Activar
                      </button>
                    )}
                    <button class="btn btn-reject" data-accion="eliminar">
                      Eliminar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* D) PREMIO SEMANAL */}
          <section>
            <div class="section-head">
              <h2 id="premio-titulo">{premioActivo ? "Editar premio activo" : "Nuevo premio semanal"}</h2>
              {premioActivo && (
                <button type="button" id="premio-nuevo" class="btn btn-ghost">
                  + Crear nuevo
                </button>
              )}
            </div>
            <form
              id="premio-form"
              class="cartel-form"
              data-id={premioActivo?.id ?? ""}
              data-imagen-url={premioActivo?.imagen_url ?? ""}
            >
              <label>
                Título *
                <input name="titulo" type="text" required value={premioActivo?.titulo ?? ""} />
              </label>
              <label>
                Descripción
                <textarea name="descripcion" rows="3">{premioActivo?.descripcion ?? ""}</textarea>
              </label>
              <label>
                Imagen del premio
                {premioActivo?.imagen_url && (
                  <span class="muted small">
                    Hay una imagen actual. Sube una nueva solo si quieres reemplazarla.
                  </span>
                )}
                <input id="premio-imagen" name="imagen" type="file" accept="image/*" />
              </label>
              <img
                id="premio-preview"
                class="cartel-preview"
                alt="Vista previa"
                src={premioActivo?.imagen_url ?? undefined}
                hidden={!premioActivo?.imagen_url}
              />
              <label>
                Válido hasta
                <input name="valido_hasta" type="date" value={premioActivo?.valido_hasta ?? ""} />
              </label>
              <label class="checkbox">
                <input name="activo" type="checkbox" checked={premioActivo?.activo ?? true} />
                Activar este premio (desactiva los demás)
              </label>
              <button type="submit" class="btn btn-primary">
                {premioActivo ? "Actualizar premio" : "Guardar premio"}
              </button>
              <p id="premio-msg" class="msg" />
            </form>
          </section>

          {/* D2) HISTORIAL DE PREMIOS */}
          <section>
            <h2>
              Historial de premios <span class="count">{premios.length}</span>
            </h2>
            {premios.length === 0 && <p class="muted">Aún no hay premios.</p>}
            <div class="foto-list">
              {premios.map((p) => (
                <div
                  class:list={["foto-row", "hist-row", { "is-active": p.activo }]}
                  data-id={p.id}
                  data-tipo="premio"
                >
                  {p.imagen_url ? (
                    <img src={p.imagen_url} alt="thumbnail" class="thumb" />
                  ) : (
                    <div class="thumb thumb-empty">—</div>
                  )}
                  <div class="foto-info">
                    <strong>{p.titulo}</strong>
                    <span class="muted small">{fmt(p.created_at)}</span>
                    <span class="active-flag">● Activo</span>
                  </div>
                  <div class="foto-actions">
                    {!p.activo && (
                      <button class="btn btn-primary" data-accion="activar">
                        Activar
                      </button>
                    )}
                    <button class="btn btn-reject" data-accion="eliminar">
                      Eliminar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* E) HISTORIAL DE FOTOS SUBIDAS */}
          <section>
            <h2>
              Historial de fotos <span class="count">{historialFotos.length}</span>
            </h2>
            {historialFotos.length === 0 && (
              <p class="muted">Aún no hay fotos subidas.</p>
            )}
            <div class="hist-grid">
              {historialFotos.map((foto) => (
                <a
                  class="hist-foto"
                  href={foto.cloudinary_url}
                  target="_blank"
                  rel="noopener"
                >
                  <img src={foto.cloudinary_url} alt="foto" loading="lazy" />
                  <div class="hist-foto-meta">
                    <span class:list={["estado", foto.estado]}>{foto.estado}</span>
                    <span class="muted small">{foto.votos_count} ★</span>
                  </div>
                  <span class="muted small hist-foto-sub">
                    {foto.nombre_autor ?? "Anónimo"} · {foto.semana}
                    {foto.ganadora ? " · 🏆" : ""}
                  </span>
                </a>
              ))}
            </div>
          </section>
        </main>
      )
    }

    {
      authed && (
        <script is:inline define:vars={{ cloudName, uploadPreset }}>
          {/* Las llamadas usan la cookie httpOnly automáticamente; no hay secreto en el cliente. */}
          // ─── Moderación de fotos pendientes ───
          document
            .querySelectorAll(".foto-row:not(.winner-row):not(.hist-row)")
            .forEach((row) => {
              row.querySelectorAll(".btn").forEach((btn) => {
                btn.addEventListener("click", async () => {
                  const fotoId = row.getAttribute("data-foto-id");
                  const accion = btn.getAttribute("data-accion");
                  row.querySelectorAll(".btn").forEach((b) => (b.disabled = true));
                  try {
                    const res = await fetch("/api/admin/moderate", {
                      method: "POST",
                      headers: { "Content-Type": "application/json" },
                      body: JSON.stringify({ fotoId, accion }),
                    });
                    const data = await res.json();
                    if (data.success) row.remove();
                    else {
                      alert("Error: " + (data.error || "no se pudo procesar"));
                      row
                        .querySelectorAll(".btn")
                        .forEach((b) => (b.disabled = false));
                    }
                  } catch {
                    alert("Error de red");
                    row
                      .querySelectorAll(".btn")
                      .forEach((b) => (b.disabled = false));
                  }
                });
              });
            });

          // ─── Marcar / quitar ganadora (toggle) ───
          function pintarBotonGanadora(btn, esGanadora) {
            btn.textContent = esGanadora ? "Quitar ganadora" : "Marcar ganadora";
            btn.classList.toggle("btn-ghost", esGanadora);
            btn.classList.toggle("btn-primary", !esGanadora);
          }
          document.querySelectorAll(".btn-winner").forEach((btn) => {
            btn.addEventListener("click", async () => {
              const row = btn.closest(".foto-row");
              const fotoId = row.getAttribute("data-foto-id");
              const marcar = !row.classList.contains("is-winner");
              btn.disabled = true;
              try {
                const res = await fetch("/api/admin/set-winner", {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({ fotoId, ganadora: marcar }),
                });
                const data = await res.json();
                if (data.success) {
                  if (marcar) {
                    // Solo una ganadora por semana: resetea el resto en la UI.
                    document.querySelectorAll(".winner-row").forEach((r) => {
                      r.classList.remove("is-winner");
                      const b = r.querySelector(".btn-winner");
                      if (b) pintarBotonGanadora(b, false);
                    });
                    row.classList.add("is-winner");
                  } else {
                    row.classList.remove("is-winner");
                  }
                  pintarBotonGanadora(btn, marcar);
                } else {
                  alert("Error: " + (data.error || "no se pudo actualizar"));
                }
              } catch {
                alert("Error de red");
              } finally {
                btn.disabled = false;
              }
            });
          });

          // ─── Vista previa de la imagen/vídeo del cartel ───
          const imagenInput = document.getElementById("cartel-imagen");
          const preview = document.getElementById("cartel-preview");
          const previewVideo = document.getElementById("cartel-preview-video");
          function limpiarPreviews() {
            preview.hidden = true;
            preview.removeAttribute("src");
            previewVideo.hidden = true;
            previewVideo.removeAttribute("src");
          }
          imagenInput?.addEventListener("change", () => {
            limpiarPreviews();
            const file = imagenInput.files && imagenInput.files[0];
            if (!file) return;
            const url = URL.createObjectURL(file);
            if (file.type.startsWith("video/")) {
              previewVideo.src = url;
              previewVideo.hidden = false;
            } else {
              preview.src = url;
              preview.hidden = false;
            }
          });

          // ─── Formulario de cartel ───
          const form = document.getElementById("cartel-form");
          const msg = document.getElementById("cartel-msg");
          form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const fd = new FormData(form);
            msg.className = "msg";

            try {
              // Si no se sube un medio nuevo, se conserva el actual (edición).
              let imagenUrl = form.dataset.imagenUrl || null;
              let mediaTipo = form.dataset.mediaTipo || "imagen";
              const file = fd.get("imagen");
              if (file && file.size > 0) {
                const esVideo = file.type.startsWith("video/");
                msg.textContent = esVideo
                  ? "Subiendo vídeo..."
                  : "Subiendo imagen...";
                const cloudData = new FormData();
                cloudData.append("file", file);
                cloudData.append("upload_preset", uploadPreset);
                // Endpoint /auto/ acepta imagen y vídeo (auto-detección).
                const up = await fetch(
                  "https://api.cloudinary.com/v1_1/" + cloudName + "/auto/upload",
                  { method: "POST", body: cloudData },
                );
                if (!up.ok) throw new Error("cloudinary");
                const upJson = await up.json();
                imagenUrl = upJson.secure_url;
                mediaTipo =
                  upJson.resource_type === "video" || esVideo
                    ? "video"
                    : "imagen";
              }

              const payload = {
                id: form.dataset.id || null,
                titulo: fd.get("titulo"),
                subtitulo: fd.get("subtitulo"),
                imagen_url: imagenUrl,
                media_tipo: mediaTipo,
                fecha_inicio: fd.get("fecha_inicio"),
                fecha_fin: fd.get("fecha_fin"),
                activo: fd.get("activo") === "on",
              };
              msg.textContent = "Guardando...";
              const res = await fetch("/api/admin/cartel", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
              });
              const data = await res.json();
              if (data.success) {
                msg.textContent = form.dataset.id
                  ? "✓ Cartel actualizado"
                  : "✓ Cartel guardado";
                msg.className = "msg ok";
                setTimeout(() => location.reload(), 700);
              } else {
                msg.textContent =
                  "Error: " + (data.error || "no se pudo guardar");
                msg.className = "msg err";
              }
            } catch {
              msg.textContent = "Error de red";
              msg.className = "msg err";
            }
          });

          // ─── Botón "Crear nuevo" cartel: vacía el form y pasa a modo creación ───
          document.getElementById("cartel-nuevo")?.addEventListener("click", () => {
            form.querySelectorAll("input, textarea").forEach((el) => {
              if (el.type === "checkbox") el.checked = true;
              else el.value = "";
            });
            form.dataset.id = "";
            form.dataset.imagenUrl = "";
            form.dataset.mediaTipo = "imagen";
            limpiarPreviews();
            const t = document.getElementById("cartel-titulo");
            if (t) t.textContent = "Nuevo cartel";
            const submitBtn = form.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.textContent = "Guardar cartel";
            msg.textContent = "";
            msg.className = "msg";
            form.querySelector('[name="titulo"]')?.focus();
          });

          // ─── Vista previa de la imagen del premio ───
          const premioImagenInput = document.getElementById("premio-imagen");
          const premioPreview = document.getElementById("premio-preview");
          premioImagenInput?.addEventListener("change", () => {
            const file = premioImagenInput.files && premioImagenInput.files[0];
            if (file) {
              premioPreview.src = URL.createObjectURL(file);
              premioPreview.hidden = false;
            } else {
              premioPreview.hidden = true;
              premioPreview.removeAttribute("src");
            }
          });

          // ─── Formulario de premio semanal ───
          const premioForm = document.getElementById("premio-form");
          const premioMsg = document.getElementById("premio-msg");
          premioForm?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const fd = new FormData(premioForm);
            premioMsg.className = "msg";

            try {
              // Si no se sube una imagen nueva, se conserva la actual (edición).
              let imagenUrl = premioForm.dataset.imagenUrl || null;
              const file = fd.get("imagen");
              if (file && file.size > 0) {
                premioMsg.textContent = "Subiendo imagen...";
                const cloudData = new FormData();
                cloudData.append("file", file);
                cloudData.append("upload_preset", uploadPreset);
                const up = await fetch(
                  "https://api.cloudinary.com/v1_1/" + cloudName + "/image/upload",
                  { method: "POST", body: cloudData },
                );
                if (!up.ok) throw new Error("cloudinary");
                const upJson = await up.json();
                imagenUrl = upJson.secure_url;
              }

              const payload = {
                id: premioForm.dataset.id || null,
                titulo: fd.get("titulo"),
                descripcion: fd.get("descripcion"),
                imagen_url: imagenUrl,
                valido_hasta: fd.get("valido_hasta"),
                activo: fd.get("activo") === "on",
              };
              premioMsg.textContent = "Guardando...";
              const res = await fetch("/api/admin/premio", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
              });
              const data = await res.json();
              if (data.success) {
                premioMsg.textContent = premioForm.dataset.id
                  ? "✓ Premio actualizado"
                  : "✓ Premio guardado";
                premioMsg.className = "msg ok";
                setTimeout(() => location.reload(), 700);
              } else {
                premioMsg.textContent =
                  "Error: " + (data.error || "no se pudo guardar");
                premioMsg.className = "msg err";
              }
            } catch {
              premioMsg.textContent = "Error de red";
              premioMsg.className = "msg err";
            }
          });

          // ─── Botón "Crear nuevo" premio: vacía el form y pasa a modo creación ───
          document.getElementById("premio-nuevo")?.addEventListener("click", () => {
            premioForm.querySelectorAll("input, textarea").forEach((el) => {
              if (el.type === "checkbox") el.checked = true;
              else el.value = "";
            });
            premioForm.dataset.id = "";
            premioForm.dataset.imagenUrl = "";
            premioPreview.hidden = true;
            premioPreview.removeAttribute("src");
            const t = document.getElementById("premio-titulo");
            if (t) t.textContent = "Nuevo premio semanal";
            const submitBtn = premioForm.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.textContent = "Guardar premio";
            premioMsg.textContent = "";
            premioMsg.className = "msg";
            premioForm.querySelector('[name="titulo"]')?.focus();
          });

          // ─── Historial de carteles/premios: activar / eliminar ───
          document.querySelectorAll(".hist-row").forEach((row) => {
            const tipo = row.getAttribute("data-tipo"); // 'cartel' | 'premio'
            const id = row.getAttribute("data-id");
            const endpoint =
              tipo === "premio" ? "/api/admin/premio" : "/api/admin/cartel";
            row.querySelectorAll(".btn").forEach((btn) => {
              btn.addEventListener("click", async () => {
                const accion = btn.getAttribute("data-accion");
                if (
                  accion === "eliminar" &&
                  !confirm("¿Eliminar definitivamente este elemento?")
                ) {
                  return;
                }
                row.querySelectorAll(".btn").forEach((b) => (b.disabled = true));
                try {
                  const res = await fetch(endpoint, {
                    method: accion === "eliminar" ? "DELETE" : "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ id }),
                  });
                  const data = await res.json();
                  if (data.success) {
                    location.reload();
                  } else {
                    alert("Error: " + (data.error || "no se pudo procesar"));
                    row
                      .querySelectorAll(".btn")
                      .forEach((b) => (b.disabled = false));
                  }
                } catch {
                  alert("Error de red");
                  row
                    .querySelectorAll(".btn")
                    .forEach((b) => (b.disabled = false));
                }
              });
            });
          });
        </script>
      )
    }

    <style>
      :root {
        --bg: var(--color-bg);
        --surface: var(--color-surface);
        --border: rgba(255, 255, 255, 0.1);
        --accent: var(--color-accent);
        --text: var(--color-text);
        --muted: var(--color-muted);
        --green: #3ad17a;
        --red: var(--color-accent3);
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, sans-serif;
        padding: 32px;
        line-height: 1.5;
      }
      main {
        max-width: 760px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 48px;
      }
      /* Login */
      .login-wrap {
        min-height: 80vh;
        justify-content: center;
        align-items: center;
      }
      .login-box {
        width: 100%;
        max-width: 360px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 32px;
      }
      .login-box input {
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 12px 14px;
        font-size: 0.95rem;
      }
      .head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 16px;
      }
      h1 {
        font-size: 1.4rem;
      }
      .tag {
        color: var(--accent);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
      }
      h2 {
        font-size: 1.05rem;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }
      .section-head h2 {
        margin-bottom: 16px;
      }
      .count {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 999px;
      }
      .muted {
        color: var(--muted);
        font-size: 0.85rem;
      }
      .small {
        font-size: 0.7rem;
      }
      .error {
        color: var(--red);
        font-size: 0.85rem;
      }
      .foto-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .foto-row {
        display: flex;
        align-items: center;
        gap: 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 12px;
      }
      .thumb {
        width: 64px;
        height: 80px;
        object-fit: cover;
        flex-shrink: 0;
        background: var(--bg);
      }
      .foto-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex: 1;
        min-width: 0;
      }
      .foto-actions {
        display: flex;
        gap: 8px;
      }
      /* Estado ganadora */
      .winner-flag {
        display: none;
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
      }
      .winner-row.is-winner {
        border-color: var(--accent);
      }
      .winner-row.is-winner .winner-flag {
        display: inline;
      }
      /* Historial carteles/premios */
      .active-flag {
        display: none;
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
      }
      .hist-row.is-active {
        border-color: var(--accent);
      }
      .hist-row.is-active .active-flag {
        display: inline;
      }
      .thumb-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        border: 1px dashed var(--border);
      }
      /* Historial de fotos */
      .hist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 10px;
      }
      .hist-foto {
        display: flex;
        flex-direction: column;
        gap: 6px;
        text-decoration: none;
        color: var(--text);
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 8px;
      }
      .hist-foto img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        background: var(--bg);
      }
      .hist-foto-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 6px;
      }
      .hist-foto-sub {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .estado {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
      }
      .estado.aprobada {
        color: var(--green);
      }
      .estado.pendiente {
        color: var(--accent);
      }
      .estado.rechazada {
        color: var(--red);
      }
      .btn {
        border: none;
        padding: 9px 16px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        color: #fff;
      }
      .btn:disabled {
        opacity: 0.5;
        cursor: default;
      }
      .btn-approve {
        background: var(--green);
        color: #04140a;
      }
      .btn-reject {
        background: var(--red);
      }
      .btn-primary {
        background: var(--accent);
        color: var(--bg);
      }
      .btn-ghost {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--muted);
      }
      .cartel-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 24px;
      }
      .cartel-form .btn-primary {
        align-self: flex-start;
      }
      .cartel-preview {
        max-width: 240px;
        border: 1px solid var(--border);
        object-fit: cover;
      }
      label {
        display: flex;
        flex-direction: column;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--muted);
      }
      label.checkbox {
        flex-direction: row;
        align-items: center;
        gap: 10px;
        color: var(--text);
      }
      input[type="text"],
      input[type="url"],
      input[type="date"],
      textarea {
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 10px 12px;
        font-size: 0.9rem;
      }
      textarea {
        font-family: inherit;
        resize: vertical;
      }
      .row {
        display: flex;
        gap: 16px;
      }
      .row label {
        flex: 1;
      }
      .msg {
        font-size: 0.85rem;
        min-height: 1.2em;
      }
      .msg.ok {
        color: var(--green);
      }
      .msg.err {
        color: var(--red);
      }
      @media (max-width: 600px) {
        .foto-row {
          flex-wrap: wrap;
        }
        .row {
          flex-direction: column;
        }
      }
    </style>
  </body>
</html>
